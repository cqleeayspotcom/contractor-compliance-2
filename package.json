{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.js",
    "start:prod": "ng serve --configuration production --proxy-config proxy.conf.js",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --code-coverage",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.html\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.html\"",
    "generate-api": "ng-openapi-gen --config ng-openapi-gen.json",
    "analyze": "ng build --stats-json && webpack-bundle-analyzer dist/stats.json",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "cypress open --e2e --browser chrome"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@stripe/stripe-js": "^9.3.1",
    "angularx-qrcode": "^21.0.1",
    "jscanify": "^1.4.2",
    "pdf-lib": "^1.17.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "cypress": "^15.13.1",
    "jsdom": "^28.0.0",
    "ng-openapi-gen": "^1.0.5",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
